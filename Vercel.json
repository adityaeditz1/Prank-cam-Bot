{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "Index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/send-photo",
      "dest": "/app.py"
    },
    {
      "src": "/webhook",
      "dest": "/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    },
    {
      "src": "/",
      "dest": "/Index.html"
    }
  ]
}
